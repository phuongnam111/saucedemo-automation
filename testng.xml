<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    Parallel execution configuration:
    - parallel="tests" → each <test> block runs in its own thread
    - thread-count="2" → 2 tests run simultaneously (Chrome + Firefox)
    - TestListener auto-captures screenshots on any test failure
-->
<suite name="SauceDemo Test Suite" parallel="tests" thread-count="2">

    <listeners>
        <listener class-name="com.saucedemo.utils.TestListener"/>
    </listeners>

    <!-- ========== CHROME EXECUTION ========== -->
    <test name="Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.saucedemo.tests.LoginTest"/>
            <class name="com.saucedemo.tests.CartCheckoutTest"/>
        </classes>
    </test>

    <!-- ========== FIREFOX EXECUTION ========== -->
    <test name="Firefox Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.saucedemo.tests.LoginTest"/>
            <class name="com.saucedemo.tests.CartCheckoutTest"/>
        </classes>
    </test>

</suite>